{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/server.js" },
    { "source": "/", "destination": "/frontend/dashboard.html" },
    { "source": "/transactions", "destination": "/frontend/transactions.html" },
    { "source": "/budgets", "destination": "/frontend/budgets.html" },
    { "source": "/analytics", "destination": "/frontend/analytics.html" },
    { "source": "/goals", "destination": "/frontend/goals.html" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ]
}