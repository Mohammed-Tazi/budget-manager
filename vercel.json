{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/server.js" },
    { "source": "/", "destination": "/frontend/dashboard.html" },
    { "source": "/app.css", "destination": "/frontend/app.css" },
    { "source": "/(.*).js", "destination": "/frontend/$1.js" },
    { "source": "/(.*)", "destination": "/frontend/$1.html" }
  ]
}